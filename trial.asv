fun = @eaf_improved;
% Initial value
x0 = [
    % Q_sSc
    50000,
    % Q_lSc
    0,
    % Q_sSl
    0,
    % Q_lSl
    0,
    %
    
    ];
options = optimset('Algorithm', 'levenberg-marquardt', 'disp', 'iter', 'LargeScale', 'off', 'TolFun', .001 ...
    , 'MaxIter', 10000000, 'MaxFunEvals', 100000);
dx = fsolve(fun, x0, options);