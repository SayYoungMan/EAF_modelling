% Radiosity of roof
J_roof = ep1*sig*T_roof^4 - (1-ep1)*(VF12*J_wall + VF13*J_sSc ...
    + VF14*J_lSc + VF15*Q_arcRAD);

% Radiosity of wall
J_wall ep2*sig*T_wall^4 - (1-ep2)*(VF21*x(4) + VF23*x(6) ...
    + VF24*x(7) + VF25*Q_arcRAD);

% Radiosity of sSc
F(6) = x(6) - ep3*sig*T_sSc^4 - (1-ep3)*(VF31*x(4) + VF32*x(5) ...
    + VF35*Q_arcRAD);

% Radiosity of lSc
F(7) = x(7) - ep4*sig*T_lSc^4 - (1-ep4)*(VF41*x(4) + VF42*x(5) ...
    + VF45*Q_arcRAD);